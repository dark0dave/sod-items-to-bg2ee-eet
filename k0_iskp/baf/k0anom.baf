IF
    Global("K0_ITEMS_BDBLUN08","GLOBAL",0)
    !BeenInParty("anomen")
THEN
    RESPONSE #100
        SetInterrupt(FALSE)
        SetGlobal("K0_ITEMS_BDBLUN08","GLOBAL",1)
        DestroyItem("BLUN04")  // Mace
        CreateItem("bdblun08",0,0,0)  // Glimmer of Hope +2
        XEquipItem("bdblun08",Myself,SLOT_WEAPON1,EQUIP)  // Glimmer of Hope +2
        SetInterrupt(FALSE)
END
