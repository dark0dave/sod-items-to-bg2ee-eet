IF
    Global("K0_ITEMS_BDAMUL11","GLOBAL",0)
    !BeenInParty("cernd")
THEN
    RESPONSE #100
        SetInterrupt(FALSE)
        SetGlobal("K0_ITEMS_BDAMUL11","GLOBAL",1)
        CreateItem("bdamul11",0,0,0)  // Lon's Amulet
        XEquipItem("bdamul11",Myself,SLOT_AMULET,EQUIP)  // Lon's Amulet
        SetInterrupt(FALSE)
END
