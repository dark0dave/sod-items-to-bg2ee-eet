ACTION_IF NOT FILE_EXISTS_IN_GAME ~ar0305.bcs~ BEGIN  //Check for existing area script first
  COMPILE ~k0_iskp/baf/k0ar0305.baf~  //Nimblefinger Gloves, Soft Feet
