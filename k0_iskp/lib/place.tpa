ACTION_IF NOT FILE_EXISTS_IN_GAME ~ar0712.bcs~ BEGIN  //Check for existing area script first
COMPILE ~k0_iskp/baf/k0ar0712.baf~    //The Uncursed Staff +1, Screaming Bagpipes*, Dread Hammer +2
    COPY_EXISTING ~ar0712.are~ ~override~
      WRITE_ASCII 0x94 k0ar0712
      END
        ELSE BEGIN
          EXTEND_BOTTOM ~ar0712.bcs~ ~k0_iskp/baf/k0ar0712.baf~
          END
            COMPILE  ~k0_iskp/baf/k0pooky.baf~  //new race script to allow pooky to use the bagpipes in combat, since his default script is shared
            COPY_EXISTING ~sevpat03.cre~ ~override~
              WRITE_ASCII 0x258 k0pooky


EXTEND_BOTTOM ~ar1200.bcs~ ~k0_iskp/baf/k0ar1200.baf~  //The Forest Queen's Benediction*, Helm of Equus*
  EXTEND_BOTTOM ~vaelasa.bcs~ ~k0_iskp/baf/k0vaela.baf~  //allows vaelasa to use the FBQ in combat
    ACTION_IF FILE_EXISTS_IN_GAME ~vaelasa.dlg~ BEGIN
       COMPILE ~k0_iskp/dlg/k0vaela.d~ //update vaelasa's dialogue to give FBQ as reward for returning acorns, if it's in her inventory
    END

