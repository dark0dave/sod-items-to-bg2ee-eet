// Import only
ACTION_IF NOT FILE_EXISTS_IN_GAME ~bdmisc32.itm~ BEGIN
  COPY ~k0_iskp/itm/bdmisc32.itm~ ~override~
    SAY NAME1 @20093
    SAY NAME2 @20361
    SAY UNIDENTIFIED_DESC @20094
    SAY DESC @20362
  COPY ~k0_iskp/spl/bdshblod.spl~ ~override~
    LPF ALTER_EFFECT
      INT_VAR
        match_opcode = 139
        parameter1   = RESOLVE_STR_REF(@40001)
    END
END
